{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build", "-DCMAKE_BUILD_TYPE=Debug"],
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "cmake: build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build"],
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["cmake: configure"]
    },
    {
      "label": "run: showmebug",
      "type": "shell",
      "command": "./build/showmebug",
      "problemMatcher": [],
      "dependsOn": ["cmake: build"]
    }
  ]
}
