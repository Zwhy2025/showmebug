#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC_DIR="$ROOT_DIR/src"
TEMPLATE_DIR="$ROOT_DIR/templates/src"
DEFAULT_BRANCH="main"
BRANCH_PREFIX="codex/lc-"

usage() {
    cat <<'EOF'
Usage:
  ./scripts/lc new <slug> [title]   Create or switch to a problem branch and reset src/ from template
  ./scripts/lc list                 List saved problem branches
  ./scripts/lc template             Switch back to the template branch

Examples:
  ./scripts/lc new palindrome-linked-list "回文链表"
  ./scripts/lc list
  ./scripts/lc template
EOF
}

require_git_repo() {
    git -C "$ROOT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
        echo "Error: git repo is not initialized in $ROOT_DIR" >&2
        echo "Run: git init -b $DEFAULT_BRANCH" >&2
        exit 1
    }
}

require_clean_tree() {
    if [[ -n "$(git -C "$ROOT_DIR" status --porcelain)" ]]; then
        echo "Error: working tree is not clean. Commit or stash changes first." >&2
        exit 1
    fi
}

ensure_template_files() {
    [[ -f "$TEMPLATE_DIR/main.cpp" && -f "$TEMPLATE_DIR/solution.hpp" ]] || {
        echo "Error: missing template files under templates/src/" >&2
        exit 1
    }
}

escape_sed_replacement() {
    printf '%s' "$1" | sed 's/[\/&]/\\&/g'
}

render_template() {
    local slug="$1"
    local title="$2"
    local escaped_slug
    local escaped_title

    escaped_slug="$(escape_sed_replacement "$slug")"
    escaped_title="$(escape_sed_replacement "$title")"

    sed \
        -e "s/__PROBLEM_SLUG__/$escaped_slug/g" \
        -e "s/__PROBLEM_TITLE__/$escaped_title/g" \
        "$TEMPLATE_DIR/main.cpp" >"$SRC_DIR/main.cpp"

    sed \
        -e "s/__PROBLEM_SLUG__/$escaped_slug/g" \
        -e "s/__PROBLEM_TITLE__/$escaped_title/g" \
        "$TEMPLATE_DIR/solution.hpp" >"$SRC_DIR/solution.hpp"
}

new_problem() {
    local slug="$1"
    local title="${2:-$slug}"
    local branch_name="${BRANCH_PREFIX}${slug}"

    require_git_repo
    require_clean_tree
    ensure_template_files

    if git -C "$ROOT_DIR" show-ref --verify --quiet "refs/heads/$branch_name"; then
        git -C "$ROOT_DIR" switch "$branch_name" >/dev/null
        echo "Switched to existing branch $branch_name"
        return
    fi

    git -C "$ROOT_DIR" switch "$DEFAULT_BRANCH" >/dev/null
    git -C "$ROOT_DIR" switch -c "$branch_name" >/dev/null
    render_template "$slug" "$title"
    git -C "$ROOT_DIR" add src/main.cpp src/solution.hpp
    git -C "$ROOT_DIR" commit -m "start $slug" >/dev/null
    echo "Created $branch_name from template"
}

list_problems() {
    require_git_repo
    git -C "$ROOT_DIR" branch --list "${BRANCH_PREFIX}*" | sed 's/^..//'
}

switch_template() {
    require_git_repo
    require_clean_tree
    git -C "$ROOT_DIR" switch "$DEFAULT_BRANCH"
}

main() {
    local command="${1:-}"
    case "$command" in
    new)
        [[ $# -ge 2 ]] || {
            usage
            exit 1
        }
        new_problem "$2" "${3:-$2}"
        ;;
    list)
        [[ $# -eq 1 ]] || {
            usage
            exit 1
        }
        list_problems
        ;;
    template)
        [[ $# -eq 1 ]] || {
            usage
            exit 1
        }
        switch_template
        ;;
    *)
        usage
        exit 1
        ;;
    esac
}

main "$@"
